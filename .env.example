# Supabase project credentials (frontend / public keys only).
# Copy this file to ".env" and fill in the values from your Supabase project:
# Project Settings -> API. NEVER put the service_role key here — it is a secret
# and this is a frontend app; the anon key + Row Level Security is all you need.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push public (VAPID) key — safe to expose. Generate a keypair and keep the
# PRIVATE key only in the Supabase Edge Function secrets (never here).
VITE_VAPID_PUBLIC_KEY=
